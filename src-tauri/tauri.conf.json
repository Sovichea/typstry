{
  "version": "0.5.0",
  "productName": "Typsastra",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Typsastra",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob: http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline' http://127.0.0.1:* http://localhost:*; font-src 'self' blob: data: http://127.0.0.1:* http://localhost:*; img-src 'self' data: blob: http://127.0.0.1:* http://localhost:*; blob-src 'self' blob:; connect-src 'self' blob: data: http://127.0.0.1:* ws://127.0.0.1:* http://localhost:* ws://localhost:*; frame-src 'self' about: data: blob: http://127.0.0.1:* http://localhost:*; worker-src 'self' blob: http://127.0.0.1:* http://localhost:*;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/examples/": "examples/"
    },
    "fileAssociations": [
      {
        "ext": ["typsastra"],
        "name": "Typsastra Project",
        "description": "Version-bound Typsastra project archive",
        "mimeType": "application/vnd.typsastra.project",
        "role": "Editor",
        "rank": "Owner",
        "exportedType": {
          "identifier": "com.typsastra.project",
          "conformsTo": ["public.data", "public.archive"]
        }
      }
    ]
  },
  "identifier": "com.typsastra.editor",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyRDlBRkEyRDhBOTdCRTIKUldUaWU2bllvcS9aRW1WUDBRRkZnNFJQZitEdlRiSWNNR1YyZ21hRnRKMXd1OUdKNVZHMUpMR3YK",
      "endpoints": [
        "https://github.com/Sovichea/typsastra/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
